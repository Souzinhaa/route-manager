# ── Database ──────────────────────────────────────────────────────────────────
# Neon (production): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ── Auth / Security ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Cross-site cookies (Vercel + Render). Requires HTTPS.
# Setting this true → SameSite=None + Secure on auth cookies.
COOKIE_SECURE=true

# Comma-separated. NEVER use "*" with credentials in production.
CORS_ORIGINS=https://your-app.vercel.app

# ── Environment ───────────────────────────────────────────────────────────────
ENV=production
PORT=8000
WEB_WORKERS=2

# ── Integrations ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=false

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
MAX_WAYPOINTS=198
