# Database
POSTGRES_DB=route_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password

# API
SECRET_KEY=change-me-min-32-chars-strong-jwt-secret
GOOGLE_MAPS_API_KEY=

# Security / limits
# Comma-separated list of allowed origins. Use specific origins in production
# (e.g. "https://yourdomain.com,https://app.yourdomain.com"). "*" disables credentials.
CORS_ORIGINS=*
MAX_UPLOAD_SIZE_MB=20
MAX_WAYPOINTS=198
AVG_SPEED_KMH=50
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_URL=http://localhost:8010
APP_PORT=8010
UPLOAD_DIR=/app/uploads
WEB_WORKERS=2

# Security flags (set to false only in dev/test, never in production)
COOKIE_SECURE=false
# CSRF_ENABLED=true
# RATELIMIT_ENABLED=true
