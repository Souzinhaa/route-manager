# ══════════════════════════════════════════════════════════════════════════════
# BACKEND (Render) — Set these in Render project settings
# ══════════════════════════════════════════════════════════════════════════════

# Neon PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://user:password@host.neon.tech/database

# Security & auth
SECRET_KEY=your-secret-key-min-32-chars-long-for-production
COOKIE_SECURE=true

# APIs
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# CORS — allow your Vercel frontend
CORS_ORIGINS=https://your-frontend.vercel.app

# Server config
PORT=8000
WEB_WORKERS=4


# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND (Vercel) — Set these in Vercel project settings
# ══════════════════════════════════════════════════════════════════════════════

# Backend API base URL (points to Render)
VITE_API_URL=https://your-backend.onrender.com


# ══════════════════════════════════════════════════════════════════════════════
# LOCAL DEV — For running locally with Docker
# ══════════════════════════════════════════════════════════════════════════════

POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=route_manager
